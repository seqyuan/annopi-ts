{
  "name": "annopi-ts",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r --parallel test:watch",
    "typecheck": "pnpm -r typecheck",
    "site:dev": "pnpm --filter annopi-site dev",
    "site:build": "pnpm --filter annopi-site build",
    "site:start": "pnpm --filter annopi-site start",
    "release": "pnpm build && pnpm test && pnpm -r publish --access public --no-git-checks"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  }
}
