{
  "name": "@seqyuan/annopi-report",
  "version": "0.1.3",
  "description": "Report helpers for annopi-ts — delegates rendering to @seqyuan/rst-renderer",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seqyuan/annopi-ts.git",
    "directory": "packages/report"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/*"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@seqyuan/rst-renderer": "catalog:"
  },
  "peerDependencies": {
    "@seqyuan/rst-cli": "catalog:"
  },
  "peerDependenciesMeta": {
    "@seqyuan/rst-cli": {
      "optional": true
    }
  },
  "devDependencies": {
    "@seqyuan/rst-cli": "catalog:",
    "@types/node": "^24.12.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  }
}
